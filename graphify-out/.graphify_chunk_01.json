    {"id": "readme_dealflow_ai", "label": "Dealflow AI: LBO & Comparable-Deal Engine", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Institutional-grade valuation and screening platform for PE/IB workflows, built on a Vercel-style aesthetic with live API integrations and a foolproof fallback architecture."},
    {"id": "readme_comps_screener", "label": "Dynamic Comps Screener", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sector-matched multiples for any public ticker with NSE/BSE auto-resolution (TCS → TCS.NS) so Indian users get actual local peer comps."},
    {"id": "readme_unlisted_target_mode", "label": "Unlisted Target Mode", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Values a private company by benchmarking against the sector's public peer group, overlaying the target row and syncing the LBO simulator and precedent benchmarks."},
    {"id": "readme_lbo_forecaster", "label": "Interactive LBO Forecaster", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multi-year debt amortization model with average-balance interest approximated non-circularly to avoid circular-reference solving; outputs Equity Required, Exit Equity Value, MOIC, and IRR."},
    {"id": "readme_sensitivity_matrix", "label": "Heatmap Sensitivity Matrix", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Classic PE grid of Exit EBITDA Multiple vs. Leverage with a defensive color spectrum (orange defensive, green profitable, red capital loss)."},
