    {"id": "readme_markdown_parser", "label": "Smart Markdown Parsing Engine", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Maps section hierarchy, splits over-bolded LLM paragraphs at the first colon (bolding only the prefix label), and strips duplicate LLM/template headers so the memo body starts cleanly at Section 1."},
    {"id": "readme_ai_fallback_architecture", "label": "Foolproof AI Fallback Architecture", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Three-tier degradation — live FMP → Groq Llama-3.1 structured-JSON generation → curated offline mock database — so the dashboard never renders empty."},
