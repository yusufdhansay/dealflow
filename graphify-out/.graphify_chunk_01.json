    {"id": "design_vercel_design_language", "label": "Vercel Design Language Analysis", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Stark black-ink-on-near-white system for a developer-platform brand; earns an engineer-facing posture through a 200-step gray scale, deliberate whitespace, and a single decorative device."},
    {"id": "design_mesh_gradient", "label": "Multi-Color Mesh Gradient", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The cyan/blue/magenta/amber mesh gradient is the brand's entire decoration system — used at hero scale only, never miniaturised, never cropped to a single colour, so it stays the singular brand mark."},
    {"id": "design_gradient_pairs", "label": "Develop/Preview/Ship Gradient Pairs", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Three named gradient pairs (develop blue→teal, preview violet→pink, ship coral→amber) mark workflow rhythm; they collapse into the single mesh gradient at hero scale."},
    {"id": "design_geist_typography", "label": "Geist Dual-Face Typography System", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Custom geometric sans (Geist) for narrative text capped at weight 600, plus Geist Mono reserved exclusively for the technical layer (code, eyebrows, labels) — the split signals 'platform for engineers'."},
    {"id": "design_negative_tracking", "label": "Aggressive Negative Letter-Spacing", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Display sizes track -2.4px to -0.6px with sentence-case, period-terminated headlines; reverting to default tracking or all-caps breaks the brand voice."},
    {"id": "design_surface_ladder", "label": "Four-Step Surface Ladder", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "canvas (white) → canvas-soft (98%) → canvas-soft-2 (95%) → primary (ink) gives every surface a deliberate step instead of ad-hoc grays."},
    {"id": "design_polarity_flip_dark_band", "label": "Polarity-Flipped Dark Band", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Switching a section surface from canvas-soft to deep ink is the brand's chief depth cue between bands, replacing heavy shadows or decorative dividers."},
    {"id": "design_stacked_shadow_elevation", "label": "Stacked-Shadow Elevation System", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multiple small offsets at 4-12% black opacity plus an inset hairline ring fake natural light while keeping card edges crisp — deliberately calmer than a single Material-style drop-shadow."},
    {"id": "design_dual_pill_radius", "label": "Dual Pill Radius Scales", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "100px pills for marketing-scale CTAs and 6px squares for in-app/nav buttons coexist deliberately, but must never be mixed on the same screen."},
    {"id": "design_example_surfaces", "label": "Auto-Derived Example Surfaces (ex-*)", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/DESIGN.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Ten kit-mirror demonstration surfaces auto-derived by scripts/derive-examples-block.mjs so downstream consumers (/preview-design, /generate-kit) re-skin the same surfaces consistently; TO_FILL markers flag missing primitives for an LLM judgment pass."},
