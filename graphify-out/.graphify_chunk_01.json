    {"id": "readme_groq_llama_fallback", "label": "Llama-3.1 Groq Fallback Intercept", "file_type": "concept", "source_file": "/Users/yusufamin/dealflow/README.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "On FMP failure, queries Groq's llama-3.1-8b-instant in Structured JSON Mode to resolve sector, generate 5 real listed local peers, and estimate realistic multiples; surfaced to the user via a green 'live fallback' badge."},
